# --- Owner (no auth in MVP; this identity is auto-seeded as the single owner) ---
APP_OWNER_EMAIL=owner@localhost
APP_OWNER_NAME=Owner

# --- Database ---
# SQLite (default, zero-setup). To use your local Postgres instead, e.g.:
#   DATABASE_URL=postgresql+psycopg://postgres:PASSWORD@localhost:5432/academic_copilot
DATABASE_URL=sqlite:///./academic_copilot.db

# --- Qdrant (embedded local mode by default; no server needed) ---
# Leave QDRANT_URL empty to use on-disk embedded mode at QDRANT_PATH.
QDRANT_URL=
QDRANT_PATH=./qdrant_data
QDRANT_COLLECTION=academic_chunks

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768
LLM_MODEL=qwen2.5:14b

# --- Ingestion ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# --- Retrieval / RAG ---
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.5
LLM_TEMPERATURE=0.2
